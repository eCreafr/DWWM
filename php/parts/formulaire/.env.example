# ==================== CONFIGURATION DU FORMULAIRE DE CONTACT ==================== #
# Copiez ce fichier en .env et remplacez les valeurs par les vôtres.
# Le fichier .env est ignoré par Git (voir .gitignore).

# Clé PUBLIQUE reCAPTCHA v3 (visible dans le HTML, fournie par Google)
RECAPTCHA_SITE_KEY=votre-clé-publique-recaptcha

# Clé SECRÈTE reCAPTCHA v3 (côté serveur uniquement, ne jamais exposer)
RECAPTCHA_SECRET_KEY=votre-clé-secrète-recaptcha

# Clé API Mandrill (Mailchimp Transactional)
MANDRILL_API_KEY=votre-clé-mandrill

# Adresse email qui reçoit les messages du formulaire
# Doit être vérifiée dans votre compte Mandrill
CONTACT_EMAIL=votre@email.fr
